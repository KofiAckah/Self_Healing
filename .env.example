# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Bearer token AlertManager uses to authenticate to the remediation webhook.
# Generate a strong random value, e.g.:  openssl rand -hex 32
REMEDIATION_TOKEN=change-me-to-a-long-random-string

# Grafana admin password (user: admin).
GF_SECURITY_ADMIN_PASSWORD=change-me

# Anthropic API key for the analyze.py RCA bonus.
# Local dev: paste it here. On the EC2: leave blank and fetch from SSM instead:
#   export ANTHROPIC_API_KEY=$(aws ssm get-parameter \
#     --name /techstream/anthropic_api_key --with-decryption \
#     --query Parameter.Value --output text)
ANTHROPIC_API_KEY=
