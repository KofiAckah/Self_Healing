# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
my_ip_cidr = "203.0.113.4/32"   # your public IP /32 (curl ifconfig.me)
key_name   = "your-ec2-keypair-name"
owner      = "your-name"

# Optional overrides:
# aws_region                   = "eu-west-1"
# instance_type                = "t3.small"
# anthropic_ssm_parameter_name = "/techstream/anthropic_api_key"
